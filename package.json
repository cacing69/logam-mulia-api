{
  "name": "logam-mulia-api",
  "version": "1.0.0",
  "main": "src/index.ts",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "tail": "wrangler tail",
    "test": "vitest",
    "test:run": "vitest run",
    "test:unit": "vitest run --exclude='**/*.integration.test.ts'",
    "test:integration": "vitest run --include='**/*.integration.test.ts'",
    "test:coverage": "vitest run --coverage",
    "db:generate": "drizzle-kit generate",
    "db:turso:push": "drizzle-kit push",
    "db:turso:push:remote": "drizzle-kit push",
    "db:turso:reset-remote": "tsx scripts/turso-reset-and-migrate.ts",
    "db:turso:studio": "drizzle-kit studio",
    "db:d1:create": "wrangler d1 create logam-mulia-daily",
    "db:d1:migrate:local": "wrangler d1 migrations apply logam_mulia_db --local",
    "db:d1:migrate:remote": "wrangler d1 migrations apply logam_mulia_db --remote",
    "db:d1:migrate": "npm run db:d1:migrate:local && npm run db:d1:migrate:remote",
    "db:d1:reset-data:local": "wrangler d1 execute logam_mulia_db --local --file=./scripts/d1-reset-migrations.sql",
    "db:d1:reset-data:remote": "wrangler d1 execute logam_mulia_db --remote --file=./scripts/d1-reset-migrations.sql",
    "db:d1:reset-and-migrate:local": "npm run db:d1:reset-data:local && npm run db:d1:migrate:local",
    "db:d1:reset-and-migrate:remote": "npm run db:d1:reset-data:remote && npm run db:d1:migrate:remote",
    "db:d1:fresh-local": "rm -rf .wrangler/state/v3/d1 && wrangler d1 migrations apply logam_mulia_db --local",
    "db:reset-remote": "npm run db:turso:reset-remote && npm run db:d1:reset-and-migrate:remote",
    "db:migrate": "npm run db:turso:push && npm run db:d1:migrate"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ibnulmutaki/logam-mulia-api.git"
  },
  "keywords": [
    "cloudflare",
    "workers",
    "api",
    "hono"
  ],
  "author": "Ibnul Mutaki",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/ibnulmutaki/logam-mulia-api/issues"
  },
  "homepage": "https://github.com/ibnulmutaki/logam-mulia-api#readme",
  "description": "Logam Mulia API - Cloudflare Workers dengan Hono framework",
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.15.2",
    "@cloudflare/workers-types": "^4.20260501.1",
    "@types/node": "^25.6.0",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5",
    "wrangler": "^4.87.0"
  },
  "dependencies": {
    "@libsql/client": "^0.17.3",
    "cheerio": "^1.2.0",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.16"
  }
}
